# Copy to .env for local reference only — do NOT commit .env
#
# Production: set these in Cloudflare Pages → reception project →
# Settings → Environment variables (Production + Preview).
#
# Static HTML cannot read env vars at runtime. After setting
# PUBLIC_TURNSTILE_SITE_KEY here, also replace TURNSTILE_SITE_KEY_PLACEHOLDER
# in index.html and he/index.html with the same site key.

# Cloudflare Turnstile — client widget (public; also paste into HTML files)
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Cloudflare Turnstile — server verify (Pages Function only)
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# n8n webhook — form submissions forwarded here after validation
# v1 test URL (swap for production — see TODO-swap-api.txt)
N8N_WEBHOOK_URL=https://automation.sababim.co.il/webhook-test/reception-form

# Optional — not used in v1 (webhook is open)
# N8N_WEBHOOK_SECRET=your-shared-secret
